@page "/settings"
@inject ThemeState ThemeState
@inject FrontendSettings FrontendSettings
@inject ApiClient ApiClient
@inject IJSRuntime JS

<div class="settings-container">
    <FluentAccordion>
        <FluentAccordionItem Heading="Appearance">
            <HeadingTemplate>
                <div class="accordion-heading">
                    <FluentIcon Value="@(new Icons.Regular.Size20.DarkTheme())" />
                    <span>Appearance</span>
                </div>
            </HeadingTemplate>
            <ChildContent>
                <div class="setting-row">
                    <div class="setting-label">
                        <span>Theme</span>
                    </div>
                    <FluentSwitch Label="@(IsDark ? "Dark" : "Light")"
                                 Value="@IsDark"
                                 ValueChanged="OnToggle" />
                </div>
            </ChildContent>
        </FluentAccordionItem>

        <FluentAccordionItem Heading="Tools">
            <HeadingTemplate>
                <div class="accordion-heading">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Wrench())" />
                    <span>Tools</span>
                </div>
            </HeadingTemplate>
            <ChildContent>
                <div class="setting-row">
                    <div class="setting-label">
                        <span>Enable CyberChef</span>
                    </div>
                    <FluentSwitch Label="@(FrontendSettings.EnableCyberChef ? "On" : "Off")"
                                 Value="@FrontendSettings.EnableCyberChef"
                                 ValueChanged="OnCyberChefToggle" />
                </div>
            </ChildContent>
        </FluentAccordionItem>

        <FluentAccordionItem Heading="Inspector">
            <HeadingTemplate>
                <div class="accordion-heading">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Search())" />
                    <span>Inspector</span>
                </div>
            </HeadingTemplate>
            <ChildContent>
                <div class="setting-row">
                    <div class="setting-label">
                        <span>Image preview (PNG, JPEG)</span>
                    </div>
                    <FluentSwitch Label="@(FrontendSettings.EnableImagePreview ? "On" : "Off")"
                                 Value="@FrontendSettings.EnableImagePreview"
                                 ValueChanged="OnImagePreviewToggle" />
                </div>
            </ChildContent>
        </FluentAccordionItem>

        <FluentAccordionItem Heading="Security">
            <HeadingTemplate>
                <div class="accordion-heading">
                    <FluentIcon Value="@(new Icons.Regular.Size20.ShieldKeyhole())" />
                    <span>Security</span>
                </div>
            </HeadingTemplate>
            <ChildContent>
                <div class="setting-row">
                    <div class="setting-label">
                        <span>Validate upstream TLS certificates</span>
                    </div>
                    <FluentSwitch Label="@(_proxyConfig.ValidateUpstreamCertificates ? "On" : "Off")"
                                 Value="@_proxyConfig.ValidateUpstreamCertificates"
                                 ValueChanged="OnValidateUpstreamCertsToggle" />
                </div>
            </ChildContent>
        </FluentAccordionItem>

        <FluentAccordionItem Heading="Session Retention">
            <HeadingTemplate>
                <div class="accordion-heading">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Delete())" />
                    <span>Session Retention</span>
                </div>
            </HeadingTemplate>
            <ChildContent>
                <div class="setting-row">
                    <div class="setting-label">
                        <span>Keep sessions forever</span>
                    </div>
                    <FluentSwitch Label="@(_retentionPolicy.Enabled ? "Retention active" : "Forever")"
                                 Value="@(!_retentionPolicy.Enabled)"
                                 ValueChanged="OnRetentionForeverToggle" />
                </div>
                @if (_retentionPolicy.Enabled)
                {
                    <div class="setting-row">
                        <div class="setting-label">
                            <span>Max age (days)</span>
                        </div>
                        <FluentNumberField TValue="int?"
                                           Value="@_retentionPolicy.MaxAgeDays"
                                           ValueChanged="OnMaxAgeDaysChanged"
                                           Min="1"
                                           Max="365"
                                           Placeholder="No limit"
                                           Style="width: 120px;" />
                    </div>
                    <div class="setting-row">
                        <div class="setting-label">
                            <span>Max session count</span>
                        </div>
                        <FluentNumberField TValue="int?"
                                           Value="@_retentionPolicy.MaxCount"
                                           ValueChanged="OnMaxCountChanged"
                                           Min="1"
                                           Max="10000"
                                           Placeholder="No limit"
                                           Style="width: 120px;" />
                    </div>
                }
            </ChildContent>
        </FluentAccordionItem>
    </FluentAccordion>
</div>

@code {
    private bool IsDark => ThemeState.Mode == DesignThemeModes.Dark;
    private RetentionPolicyDto _retentionPolicy = new();
    private FrontendProxyConfig _proxyConfig = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await FrontendSettings.LoadAsync(JS);
            try
            {
                _retentionPolicy = await ApiClient.GetRetentionPolicyAsync();
            }
            catch
            {
                // API may not be available yet
            }
            try
            {
                _proxyConfig = await ApiClient.GetProxyConfigAsync();
            }
            catch
            {
                // API may not be available yet
            }
            StateHasChanged();
        }
    }

    private void OnToggle(bool value)
    {
        ThemeState.SetMode(value ? DesignThemeModes.Dark : DesignThemeModes.Light);
    }

    private async Task OnCyberChefToggle(bool value)
    {
        await FrontendSettings.SetEnableCyberChefAsync(JS, value);
    }

    private async Task OnImagePreviewToggle(bool value)
    {
        await FrontendSettings.SetEnableImagePreviewAsync(JS, value);
    }

    private async Task OnRetentionForeverToggle(bool keepForever)
    {
        _retentionPolicy.Enabled = !keepForever;
        await ApiClient.SaveRetentionPolicyAsync(_retentionPolicy);
    }

    private async Task OnMaxAgeDaysChanged(int? value)
    {
        _retentionPolicy.MaxAgeDays = value;
        await ApiClient.SaveRetentionPolicyAsync(_retentionPolicy);
    }

    private async Task OnMaxCountChanged(int? value)
    {
        _retentionPolicy.MaxCount = value;
        await ApiClient.SaveRetentionPolicyAsync(_retentionPolicy);
    }

    private async Task OnValidateUpstreamCertsToggle(bool value)
    {
        _proxyConfig.ValidateUpstreamCertificates = value;
        await ApiClient.SaveProxyConfigAsync(_proxyConfig);
    }
}

<style>
.settings-container {
    max-width: 600px;
}

.accordion-heading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
}

.setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
}

.setting-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
</style>
