@inject IJSRuntime JS
@inject FrontendSettings FrontendSettings
@inject NavigationManager NavigationManager
@inject ApiClient ApiClient
@inject KeyboardShortcutService KeyboardShortcuts
@using shmoxy.frontend.services
@using shmoxy.shared
@using shmoxy.shared.ipc
@implements IDisposable

<div class="detail-overlay" @onclick="OnClose" @onkeydown="HandleKeyDown" tabindex="0" @ref="overlayRef">
    <div class="detail-panel" @onclick:stopPropagation="true">
        <div class="detail-header">
            <div class="detail-title">
                <span class="method-badge method-@Row.Method.ToLowerInvariant()">@Row.Method</span>
                <span class="detail-url" title="@Row.Url">@Row.Url</span>
            </div>
            <div class="detail-meta">
                @if (Row.StatusCode.HasValue)
                {
                    <span class="status-badge status-@GetStatusClass(Row.StatusCode.Value)">@Row.StatusCode</span>
                }
                @if (Row.Duration.HasValue)
                {
                    <span class="detail-duration">@($"{Row.Duration.Value.TotalMilliseconds:F0}") ms</span>
                }
                <span class="detail-time">@Row.Timestamp.ToString("HH:mm:ss.fff")</span>
            </div>
            <button class="close-button" @onclick="OnClose" title="Close (Esc)">&times;</button>

            @if (Row.Timing is { } t)
            {
                var total = (t.ConnectMs ?? 0) + (t.TlsMs ?? 0) + t.SendMs + t.WaitMs + t.ReceiveMs;
                <div class="timing-breakdown">
                    @if (t.Reused)
                    {
                        <span class="timing-reused-badge">reused</span>
                    }
                    <div class="timing-bar">
                        @if (t.ConnectMs is > 0)
                        {
                            <div class="timing-segment timing-connect"
                                 style="width: @(SegmentPercent(t.ConnectMs.Value, total))%"
                                 title="Connect: @($"{t.ConnectMs:F1}") ms">
                            </div>
                        }
                        @if (t.TlsMs is > 0)
                        {
                            <div class="timing-segment timing-tls"
                                 style="width: @(SegmentPercent(t.TlsMs.Value, total))%"
                                 title="TLS: @($"{t.TlsMs:F1}") ms">
                            </div>
                        }
                        @if (t.SendMs > 0)
                        {
                            <div class="timing-segment timing-send"
                                 style="width: @(SegmentPercent(t.SendMs, total))%"
                                 title="Send: @($"{t.SendMs:F1}") ms">
                            </div>
                        }
                        @if (t.WaitMs > 0)
                        {
                            <div class="timing-segment timing-wait"
                                 style="width: @(SegmentPercent(t.WaitMs, total))%"
                                 title="Wait (TTFB): @($"{t.WaitMs:F1}") ms">
                            </div>
                        }
                        @if (t.ReceiveMs > 0)
                        {
                            <div class="timing-segment timing-receive"
                                 style="width: @(SegmentPercent(t.ReceiveMs, total))%"
                                 title="Receive: @($"{t.ReceiveMs:F1}") ms">
                            </div>
                        }
                    </div>
                    <div class="timing-legend">
                        @if (t.ConnectMs.HasValue)
                        {
                            <span class="timing-legend-item"><span class="timing-dot timing-connect"></span>Connect @($"{t.ConnectMs:F1}") ms</span>
                        }
                        @if (t.TlsMs.HasValue)
                        {
                            <span class="timing-legend-item"><span class="timing-dot timing-tls"></span>TLS @($"{t.TlsMs:F1}") ms</span>
                        }
                        <span class="timing-legend-item"><span class="timing-dot timing-send"></span>Send @($"{t.SendMs:F1}") ms</span>
                        <span class="timing-legend-item"><span class="timing-dot timing-wait"></span>Wait @($"{t.WaitMs:F1}") ms</span>
                        <span class="timing-legend-item"><span class="timing-dot timing-receive"></span>Receive @($"{t.ReceiveMs:F1}") ms</span>
                    </div>
                </div>
            }
        </div>

        <div class="detail-tabs">
            <button class="tab @(activeTab == "request" ? "active" : "")" @onclick='() => SetTab("request")'>Request</button>
            <button class="tab @(activeTab == "response" ? "active" : "")" @onclick='() => SetTab("response")'>Response</button>
            <div class="tab-actions">
                <button class="copy-curl-button" @onclick="CopyAsCurl" title="Copy as cURL command">
                    @(_curlCopied ? "Copied!" : "Copy as cURL")
                </button>
                <button class="resend-button" @onclick="OpenResendEditor">Resend</button>
                <button class="break-button @(_breakConfirmed ? "active" : "")" @onclick="OnBreakClick" title="Break on requests matching this URL">
                    @(_breakConfirmed ? "Breaking" : "Break")
                </button>
            </div>
        </div>

        <div id="detail-content" class="detail-body">
            @if (activeTab == "request")
            {
                <div class="section">
                    <div class="section-header">
                        <h3>Headers</h3>
                    </div>
                    @if (Row.RequestHeaders.Count > 0)
                    {
                        <table class="headers-table">
                            @foreach (var header in Row.RequestHeaders)
                            {
                                var jwtKey = $"request-{header.Key}";
                                var bearerToken = IsAuthorizationBearer(header) ? JwtDecoder.ExtractBearerToken(header.Value) : null;
                                var isJwt = bearerToken != null && JwtDecoder.IsJwt(bearerToken);
                                <tr>
                                    <td class="header-name">@header.Key</td>
                                    <td class="header-value">
                                        @if (isJwt)
                                        {
                                            <div class="jwt-header">
                                                <div class="jwt-toggle">
                                                    <button class="jwt-decode-btn @(jwtExpanded.Contains(jwtKey) ? "active" : "")"
                                                            @onclick="() => ToggleJwt(jwtKey)">
                                                        @(jwtExpanded.Contains(jwtKey) ? "Raw" : "Decode JWT")
                                                    </button>
                                                    <button class="jwt-copy-btn" @onclick="() => CopyToClipboard(bearerToken)" title="Copy JWT token">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                                    </button>
                                                </div>
                                                @if (jwtExpanded.Contains(jwtKey))
                                                {
                                                    var decoded = JwtDecoder.Decode(bearerToken!);
                                                    if (decoded != null)
                                                    {
                                                        <div class="jwt-decoded">
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Header</span>
                                                                <pre class="jwt-json"><code class="language-json">@decoded.Header</code></pre>
                                                            </div>
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Payload</span>
                                                                <pre class="jwt-json"><code class="language-json">@decoded.Payload</code></pre>
                                                            </div>
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Signature</span>
                                                                <code class="jwt-signature">@decoded.Signature</code>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    @header.Value
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            @header.Value
                                        }
                                    </td>
                                </tr>
                            }
                        </table>
                    }
                    else
                    {
                        <p class="no-data">No headers captured</p>
                    }
                </div>

                <div class="section">
                    <div class="section-header">
                        <h3>Body</h3>
                        @if (!string.IsNullOrEmpty(Row.RequestBody))
                        {
                            <div class="section-actions">
                                <button class="copy-button" @onclick="() => CopyToClipboard(Row.RequestBody)">Copy</button>
                                @if (FrontendSettings.EnableCyberChef)
                                {
                                    <button class="copy-button" @onclick="() => SendToCyberChef(Row.RequestBody)">CyberChef</button>
                                }
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Row.RequestBody))
                    {
                        var (formatted, lang) = FormatBody(Row.RequestBody, Row.RequestHeaders);
                        <pre class="code-block"><code id="request-body-code" class="language-@lang">@formatted</code></pre>
                    }
                    else
                    {
                        <p class="no-data">No body</p>
                    }
                </div>
            }
            else
            {
                <div class="section">
                    <div class="section-header">
                        <h3>Headers</h3>
                    </div>
                    @if (Row.ResponseHeaders.Count > 0)
                    {
                        <table class="headers-table">
                            @foreach (var header in Row.ResponseHeaders)
                            {
                                var jwtKey = $"response-{header.Key}";
                                var bearerToken = IsAuthorizationBearer(header) ? JwtDecoder.ExtractBearerToken(header.Value) : null;
                                var isJwt = bearerToken != null && JwtDecoder.IsJwt(bearerToken);
                                <tr>
                                    <td class="header-name">@header.Key</td>
                                    <td class="header-value">
                                        @if (isJwt)
                                        {
                                            <div class="jwt-header">
                                                <div class="jwt-toggle">
                                                    <button class="jwt-decode-btn @(jwtExpanded.Contains(jwtKey) ? "active" : "")"
                                                            @onclick="() => ToggleJwt(jwtKey)">
                                                        @(jwtExpanded.Contains(jwtKey) ? "Raw" : "Decode JWT")
                                                    </button>
                                                    <button class="jwt-copy-btn" @onclick="() => CopyToClipboard(bearerToken)" title="Copy JWT token">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                                    </button>
                                                </div>
                                                @if (jwtExpanded.Contains(jwtKey))
                                                {
                                                    var decoded = JwtDecoder.Decode(bearerToken!);
                                                    if (decoded != null)
                                                    {
                                                        <div class="jwt-decoded">
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Header</span>
                                                                <pre class="jwt-json"><code class="language-json">@decoded.Header</code></pre>
                                                            </div>
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Payload</span>
                                                                <pre class="jwt-json"><code class="language-json">@decoded.Payload</code></pre>
                                                            </div>
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Signature</span>
                                                                <code class="jwt-signature">@decoded.Signature</code>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    @header.Value
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            @header.Value
                                        }
                                    </td>
                                </tr>
                            }
                        </table>
                    }
                    else
                    {
                        <p class="no-data">No headers captured</p>
                    }
                </div>

                <div class="section">
                    <div class="section-header">
                        <h3>Body</h3>
                        @if (!string.IsNullOrEmpty(Row.ResponseBody))
                        {
                            <div class="section-actions">
                                <button class="copy-button" @onclick="() => CopyToClipboard(Row.ResponseBody)">Copy</button>
                                @if (FrontendSettings.EnableCyberChef)
                                {
                                    <button class="copy-button" @onclick="() => SendToCyberChef(Row.ResponseBody, Row.ResponseBodyBase64)">CyberChef</button>
                                }
                            </div>
                        }
                    </div>
                    @if (FrontendSettings.EnableImagePreview && IsImageResponse())
                    {
                        <div class="image-preview">
                            <img src="@ImageContentTypeDetector.BuildDataUri(Row.ResponseContentType!, Row.ResponseBodyBase64!)"
                                 alt="Response image preview"
                                 class="preview-image" />
                            <p class="image-info">@Row.ResponseContentType — @FormatBytes(Row.ResponseBodyBase64!.Length * 3 / 4)</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(Row.ResponseBody))
                    {
                        var (formatted, lang) = FormatBody(Row.ResponseBody, Row.ResponseHeaders);
                        <pre class="code-block"><code id="response-body-code" class="language-@lang">@formatted</code></pre>
                    }
                    else
                    {
                        <p class="no-data">No body</p>
                    }
                </div>
            }
        </div>

        @if (_showResendEditor)
        {
            <div class="resend-editor">
                <div class="resend-header">
                    <h3>Resend Request</h3>
                    <button class="close-button" @onclick="CloseResendEditor">&times;</button>
                </div>
                <div class="resend-form">
                    <div class="resend-row">
                        <select @bind="_resendMethod" class="resend-method">
                            <option>GET</option>
                            <option>POST</option>
                            <option>PUT</option>
                            <option>PATCH</option>
                            <option>DELETE</option>
                            <option>HEAD</option>
                            <option>OPTIONS</option>
                        </select>
                        <input type="text" @bind="_resendUrl" class="resend-url" placeholder="URL" />
                    </div>
                    <div class="resend-section">
                        <label>Headers</label>
                        <textarea @bind="_resendHeaders" class="resend-textarea" rows="6" placeholder="Header-Name: value"></textarea>
                    </div>
                    <div class="resend-section">
                        <label>Body</label>
                        <textarea @bind="_resendBody" class="resend-textarea" rows="8" placeholder="Request body"></textarea>
                    </div>
                    <div class="resend-actions">
                        <button class="resend-send-button" @onclick="SendResendRequest" disabled="@_resendSending">
                            @(_resendSending ? "Sending..." : "Send")
                        </button>
                        @if (_resendError != null)
                        {
                            <span class="resend-error">@_resendError</span>
                        }
                        @if (_resendStatusCode.HasValue)
                        {
                            <span class="resend-status status-@GetStatusClass(_resendStatusCode.Value)">@_resendStatusCode</span>
                        }
                    </div>

                    @if (_resendResponse != null)
                    {
                        <div class="resend-response">
                            <div class="section">
                                <div class="section-header">
                                    <h3>Response Headers</h3>
                                </div>
                                @if (_resendResponse.Headers.Count > 0)
                                {
                                    <table class="headers-table">
                                        @foreach (var header in _resendResponse.Headers)
                                        {
                                            <tr>
                                                <td class="header-name">@header.Key</td>
                                                <td class="header-value">@header.Value</td>
                                            </tr>
                                        }
                                    </table>
                                }
                            </div>

                            <div class="section">
                                <div class="section-header">
                                    <h3>Response Body</h3>
                                    @if (!string.IsNullOrEmpty(GetResendResponseBody()))
                                    {
                                        <div class="section-actions">
                                            <button class="copy-button" @onclick="() => CopyToClipboard(GetResendResponseBody())">Copy</button>
                                        </div>
                                    }
                                </div>
                                @if (_resendResponse.IsBase64)
                                {
                                    <p class="no-data">Binary response (@(_resendResponse.ContentType ?? "unknown type"), @FormatBytes(Convert.FromBase64String(_resendResponse.Body).Length))</p>
                                }
                                else if (!string.IsNullOrEmpty(_resendResponse.Body))
                                {
                                    var (formatted, lang) = PayloadFormatter.Format(_resendResponse.Body, _resendResponse.ContentType);
                                    <pre class="code-block"><code class="language-@lang">@formatted</code></pre>
                                }
                                else
                                {
                                    <p class="no-data">No body</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public InspectionRow Row { get; set; } = default!;

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public IReadOnlyList<InspectionRow> FilteredRows { get; set; } = Array.Empty<InspectionRow>();

    [Parameter]
    public EventCallback<InspectionRow> OnNavigate { get; set; }

    private string activeTab = "request";
    private ElementReference overlayRef;
    private HashSet<string> jwtExpanded = new();

    private async Task SetTab(string tab)
    {
        activeTab = tab;
        StateHasChanged();
        await Task.Yield();
        await HighlightCode();
    }

    protected override void OnInitialized()
    {
        KeyboardShortcuts.OnShortcutTriggered += OnGlobalShortcut;
        KeyboardShortcuts.OnResendRequested += OnResendShortcut;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await overlayRef.FocusAsync();
            }
            catch (JSDisconnectedException) { }
            await HighlightCode();
        }
    }

    private void OnGlobalShortcut(string action)
    {
        if (action == "switch-tab")
        {
            InvokeAsync(async () =>
            {
                await SetTab(activeTab == "request" ? "response" : "request");
            });
        }
    }

    private void OnResendShortcut()
    {
        InvokeAsync(() =>
        {
            OpenResendEditor();
            StateHasChanged();
        });
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape":
                await OnClose.InvokeAsync();
                break;
            case "ArrowDown":
                await NavigateToAdjacentRow(1);
                break;
            case "ArrowUp":
                await NavigateToAdjacentRow(-1);
                break;
        }
    }

    private async Task NavigateToAdjacentRow(int direction)
    {
        if (FilteredRows.Count == 0) return;

        var currentIndex = -1;
        for (int i = 0; i < FilteredRows.Count; i++)
        {
            if (FilteredRows[i].Id == Row.Id)
            {
                currentIndex = i;
                break;
            }
        }

        if (currentIndex < 0) return;

        var nextIndex = currentIndex + direction;
        if (nextIndex >= 0 && nextIndex < FilteredRows.Count)
        {
            await OnNavigate.InvokeAsync(FilteredRows[nextIndex]);
        }
    }

    private async Task HighlightCode()
    {
        try
        {
            await JS.InvokeVoidAsync("syntaxHighlight.highlightAll", "detail-content");
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected
        }
    }

    private bool IsImageResponse()
    {
        return !string.IsNullOrEmpty(Row.ResponseBodyBase64)
            && !string.IsNullOrEmpty(Row.ResponseContentType)
            && ImageContentTypeDetector.IsImageContentType(Row.ResponseContentType);
    }

    private static string FormatBytes(int bytes)
    {
        return bytes switch
        {
            < 1024 => $"{bytes} B",
            < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
            _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
        };
    }

    private static (string FormattedContent, string Language) FormatBody(string body, List<KeyValuePair<string, string>> headers)
    {
        var contentType = headers.GetHeaderValue("Content-Type");
        return PayloadFormatter.Format(body, contentType);
    }

    private async Task CopyToClipboard(string? text)
    {
        if (string.IsNullOrEmpty(text)) return;
        try
        {
            await JS.InvokeVoidAsync("clipboard.copyText", text);
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected
        }
    }

    private void SendToCyberChef(string? body, string? bodyBase64 = null)
    {
        if (string.IsNullOrEmpty(body) && string.IsNullOrEmpty(bodyBase64)) return;
        var base64 = bodyBase64 ?? Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(body!));
        NavigationManager.NavigateTo($"/cyberchef?input={Uri.EscapeDataString(base64)}");
    }

    private static bool IsAuthorizationBearer(KeyValuePair<string, string> header)
    {
        return header.Key.Equals("Authorization", StringComparison.OrdinalIgnoreCase)
            && header.Value.StartsWith("Bearer ", StringComparison.OrdinalIgnoreCase);
    }

    private async Task ToggleJwt(string key)
    {
        if (!jwtExpanded.Remove(key))
            jwtExpanded.Add(key);

        StateHasChanged();
        await Task.Yield();
        await HighlightCode();
    }

    private static string SegmentPercent(double value, double total)
    {
        if (total <= 0) return "0";
        var pct = value / total * 100;
        // Ensure visible segments get at least 2% width
        if (pct > 0 && pct < 2) pct = 2;
        return pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
    }

    private static string GetStatusClass(int statusCode) => statusCode switch
    {
        >= 200 and < 300 => "success",
        >= 300 and < 400 => "redirect",
        >= 400 and < 500 => "client-error",
        >= 500 => "server-error",
        _ => "unknown"
    };

    private bool _curlCopied;

    private async Task CopyAsCurl()
    {
        var curl = GenerateCurlCommand(Row);
        try
        {
            await JS.InvokeVoidAsync("clipboard.copyText", curl);
            _curlCopied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _curlCopied = false;
            StateHasChanged();
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected
        }
    }

    private static string GenerateCurlCommand(InspectionRow row)
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("curl");

        if (row.Method != "GET")
        {
            sb.Append($" -X {row.Method}");
        }

        sb.Append($" '{EscapeSingleQuote(row.Url)}'");

        foreach (var header in row.RequestHeaders)
        {
            sb.Append($" \\\n  -H '{EscapeSingleQuote(header.Key)}: {EscapeSingleQuote(header.Value)}'");
        }

        if (!string.IsNullOrEmpty(row.RequestBody))
        {
            sb.Append($" \\\n  -d '{EscapeSingleQuote(row.RequestBody)}'");
        }

        return sb.ToString();
    }

    private static string EscapeSingleQuote(string value)
    {
        return value.Replace("'", "'\\''");
    }

    // Resend editor state
    private bool _showResendEditor;
    private string _resendMethod = "GET";
    private string _resendUrl = "";
    private string _resendHeaders = "";
    private string _resendBody = "";
    private bool _resendSending;
    private string? _resendError;
    private int? _resendStatusCode;
    private ResendResponseDto? _resendResponse;

    private void OpenResendEditor()
    {
        _resendMethod = Row.Method;
        _resendUrl = Row.Url;
        _resendHeaders = string.Join("\n", Row.RequestHeaders.Select(kvp => $"{kvp.Key}: {kvp.Value}"));
        _resendBody = Row.RequestBody ?? "";
        _resendError = null;
        _resendStatusCode = null;
        _resendResponse = null;
        _showResendEditor = true;
    }

    private void CloseResendEditor()
    {
        _showResendEditor = false;
    }

    private async Task SendResendRequest()
    {
        _resendSending = true;
        _resendError = null;
        _resendStatusCode = null;
        StateHasChanged();

        try
        {
            var headers = new List<KeyValuePair<string, string>>();
            foreach (var line in _resendHeaders.Split('\n', StringSplitOptions.RemoveEmptyEntries))
            {
                var colonIndex = line.IndexOf(':');
                if (colonIndex > 0)
                {
                    headers.Add(new KeyValuePair<string, string>(line[..colonIndex].Trim(), line[(colonIndex + 1)..].Trim()));
                }
            }

            var request = new ResendRequestDto
            {
                Method = _resendMethod,
                Url = _resendUrl,
                Headers = headers,
                Body = string.IsNullOrWhiteSpace(_resendBody) ? null : _resendBody
            };

            var response = await ApiClient.ResendRequestAsync(request);
            _resendStatusCode = response.StatusCode;
            _resendResponse = response;
        }
        catch (Exception ex)
        {
            _resendError = ex.Message;
        }
        finally
        {
            _resendSending = false;
        }
    }

    private string? GetResendResponseBody()
    {
        if (_resendResponse == null || _resendResponse.IsBase64)
            return null;
        return _resendResponse.Body;
    }

    // Quick-break state
    private bool _breakConfirmed;

    private async Task OnBreakClick()
    {
        if (_breakConfirmed) return;

        try
        {
            // Extract URL path pattern (ignore query string for matching)
            var uri = new Uri(Row.Url);
            var urlPattern = uri.AbsolutePath;

            await ApiClient.AddBreakpointRuleAsync(Row.Method, urlPattern);
            _breakConfirmed = true;
        }
        catch
        {
            // Silently fail — UI won't show active state
        }
    }

