@page "/about"
@inject ProxyStatusService ProxyStatusService
@inject ApiClient ApiClient

<h1>About</h1>

<div class="about-container">
    <FluentCard>
        <div class="about-section">
            <img src="_content/shmoxy.frontend/icon.png" alt="Shmoxy icon" class="about-icon" />
            <h3>Shmoxy</h3>
            <table class="version-table">
                <tr><td>Frontend</td><td>@_frontendVersion</td></tr>
                <tr><td>API</td><td>@_apiVersion</td></tr>
                <tr><td>Proxy</td><td>@_proxyVersion</td></tr>
            </table>
            <p>
                Licensed under the
                <a href="https://github.com/phaser/shmoxy/blob/main/LICENSE" target="_blank" rel="noopener noreferrer">MIT License</a>.
            </p>
        </div>
    </FluentCard>

    <FluentCard>
        <div class="about-section">
            <h3>Third-Party Software</h3>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>License</th>
                        <th>Link</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dep in _thirdPartyDeps)
                    {
                        <tr>
                            <td>@dep.Name</td>
                            <td>@dep.License</td>
                            <td>
                                <a href="@dep.Url" target="_blank" rel="noopener noreferrer">GitHub</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </FluentCard>
</div>

@code {
    private string _frontendVersion = "";
    private string _apiVersion = "Loading...";
    private string _proxyVersion = "Not connected";

    private static readonly List<ThirdPartyDep> _thirdPartyDeps =
    [
        new("CyberChef", "Apache 2.0", "https://github.com/gchq/CyberChef"),
    ];

    private static string GetInformationalVersion(System.Reflection.Assembly assembly)
    {
        return System.Reflection.CustomAttributeExtensions
            .GetCustomAttribute<System.Reflection.AssemblyInformationalVersionAttribute>(assembly)?.InformationalVersion
            ?? assembly.GetName().Version?.ToString(3)
            ?? "unknown";
    }

    protected override void OnInitialized()
    {
        _frontendVersion = GetInformationalVersion(typeof(App).Assembly);

        var status = ProxyStatusService.CurrentStatus;
        if (status.IsRunning && !string.IsNullOrEmpty(status.ProxyVersion))
            _proxyVersion = status.ProxyVersion;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _apiVersion = await ApiClient.GetApiVersionAsync() ?? "unknown";
            StateHasChanged();
        }
    }

    private sealed record ThirdPartyDep(string Name, string License, string Url);
}

<style>
.about-container {
    max-width: 600px;
}

.about-section h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-weight: 600;
}

.about-section p {
    margin: 0.5rem 0;
}

.about-section a {
    color: var(--accent-foreground-rest);
}

.about-icon {
    width: 128px;
    height: 128px;
    margin-bottom: 1rem;
}

.version-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin: 0.75rem 0;
}

.version-table td {
    padding: 4px 8px;
    border-bottom: 1px solid var(--neutral-stroke-divider-rest);
}

.version-table td:first-child {
    font-weight: 600;
    width: 100px;
    color: var(--neutral-foreground-hint);
}

.version-table td:last-child {
    font-family: monospace;
}
</style>
