@inject IJSRuntime JS
@inject FrontendSettings FrontendSettings
@inject NavigationManager NavigationManager
@inject ApiClient ApiClient
@using shmoxy.frontend.services

<div class="detail-overlay" @onclick="OnClose" @onkeydown="HandleKeyDown" tabindex="0" @ref="overlayRef">
    <div class="detail-panel" @onclick:stopPropagation="true">
        <div class="detail-header">
            <div class="detail-title">
                <span class="method-badge method-@Row.Method.ToLowerInvariant()">@Row.Method</span>
                <span class="detail-url" title="@Row.Url">@Row.Url</span>
            </div>
            <div class="detail-meta">
                @if (Row.StatusCode.HasValue)
                {
                    <span class="status-badge status-@GetStatusClass(Row.StatusCode.Value)">@Row.StatusCode</span>
                }
                @if (Row.Duration.HasValue)
                {
                    <span class="detail-duration">@($"{Row.Duration.Value.TotalMilliseconds:F0}") ms</span>
                }
                <span class="detail-time">@Row.Timestamp.ToString("HH:mm:ss.fff")</span>
            </div>
            <button class="close-button" @onclick="OnClose" title="Close (Esc)">&times;</button>
        </div>

        <div class="detail-tabs">
            <button class="tab @(activeTab == "request" ? "active" : "")" @onclick='() => SetTab("request")'>Request</button>
            <button class="tab @(activeTab == "response" ? "active" : "")" @onclick='() => SetTab("response")'>Response</button>
            <div class="tab-actions">
                <button class="resend-button" @onclick="OpenResendEditor">Resend</button>
            </div>
        </div>

        <div id="detail-content" class="detail-body">
            @if (activeTab == "request")
            {
                <div class="section">
                    <div class="section-header">
                        <h3>Headers</h3>
                    </div>
                    @if (Row.RequestHeaders.Count > 0)
                    {
                        <table class="headers-table">
                            @foreach (var header in Row.RequestHeaders)
                            {
                                var jwtKey = $"request-{header.Key}";
                                var bearerToken = IsAuthorizationBearer(header) ? JwtDecoder.ExtractBearerToken(header.Value) : null;
                                var isJwt = bearerToken != null && JwtDecoder.IsJwt(bearerToken);
                                <tr>
                                    <td class="header-name">@header.Key</td>
                                    <td class="header-value">
                                        @if (isJwt)
                                        {
                                            <div class="jwt-header">
                                                <div class="jwt-toggle">
                                                    <button class="jwt-decode-btn @(jwtExpanded.Contains(jwtKey) ? "active" : "")"
                                                            @onclick="() => ToggleJwt(jwtKey)">
                                                        @(jwtExpanded.Contains(jwtKey) ? "Raw" : "Decode JWT")
                                                    </button>
                                                    <button class="jwt-copy-btn" @onclick="() => CopyToClipboard(bearerToken)" title="Copy JWT token">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                                    </button>
                                                </div>
                                                @if (jwtExpanded.Contains(jwtKey))
                                                {
                                                    var decoded = JwtDecoder.Decode(bearerToken!);
                                                    if (decoded != null)
                                                    {
                                                        <div class="jwt-decoded">
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Header</span>
                                                                <pre class="jwt-json"><code class="language-json">@decoded.Header</code></pre>
                                                            </div>
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Payload</span>
                                                                <pre class="jwt-json"><code class="language-json">@decoded.Payload</code></pre>
                                                            </div>
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Signature</span>
                                                                <code class="jwt-signature">@decoded.Signature</code>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    @header.Value
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            @header.Value
                                        }
                                    </td>
                                </tr>
                            }
                        </table>
                    }
                    else
                    {
                        <p class="no-data">No headers captured</p>
                    }
                </div>

                <div class="section">
                    <div class="section-header">
                        <h3>Body</h3>
                        @if (!string.IsNullOrEmpty(Row.RequestBody))
                        {
                            <div class="section-actions">
                                <button class="copy-button" @onclick="() => CopyToClipboard(Row.RequestBody)">Copy</button>
                                @if (FrontendSettings.EnableCyberChef)
                                {
                                    <button class="copy-button" @onclick="() => SendToCyberChef(Row.RequestBody)">CyberChef</button>
                                }
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Row.RequestBody))
                    {
                        var (formatted, lang) = FormatBody(Row.RequestBody, Row.RequestHeaders);
                        <pre class="code-block"><code id="request-body-code" class="language-@lang">@formatted</code></pre>
                    }
                    else
                    {
                        <p class="no-data">No body</p>
                    }
                </div>
            }
            else
            {
                <div class="section">
                    <div class="section-header">
                        <h3>Headers</h3>
                    </div>
                    @if (Row.ResponseHeaders.Count > 0)
                    {
                        <table class="headers-table">
                            @foreach (var header in Row.ResponseHeaders)
                            {
                                var jwtKey = $"response-{header.Key}";
                                var bearerToken = IsAuthorizationBearer(header) ? JwtDecoder.ExtractBearerToken(header.Value) : null;
                                var isJwt = bearerToken != null && JwtDecoder.IsJwt(bearerToken);
                                <tr>
                                    <td class="header-name">@header.Key</td>
                                    <td class="header-value">
                                        @if (isJwt)
                                        {
                                            <div class="jwt-header">
                                                <div class="jwt-toggle">
                                                    <button class="jwt-decode-btn @(jwtExpanded.Contains(jwtKey) ? "active" : "")"
                                                            @onclick="() => ToggleJwt(jwtKey)">
                                                        @(jwtExpanded.Contains(jwtKey) ? "Raw" : "Decode JWT")
                                                    </button>
                                                    <button class="jwt-copy-btn" @onclick="() => CopyToClipboard(bearerToken)" title="Copy JWT token">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                                    </button>
                                                </div>
                                                @if (jwtExpanded.Contains(jwtKey))
                                                {
                                                    var decoded = JwtDecoder.Decode(bearerToken!);
                                                    if (decoded != null)
                                                    {
                                                        <div class="jwt-decoded">
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Header</span>
                                                                <pre class="jwt-json"><code class="language-json">@decoded.Header</code></pre>
                                                            </div>
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Payload</span>
                                                                <pre class="jwt-json"><code class="language-json">@decoded.Payload</code></pre>
                                                            </div>
                                                            <div class="jwt-section">
                                                                <span class="jwt-label">Signature</span>
                                                                <code class="jwt-signature">@decoded.Signature</code>
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    @header.Value
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            @header.Value
                                        }
                                    </td>
                                </tr>
                            }
                        </table>
                    }
                    else
                    {
                        <p class="no-data">No headers captured</p>
                    }
                </div>

                <div class="section">
                    <div class="section-header">
                        <h3>Body</h3>
                        @if (!string.IsNullOrEmpty(Row.ResponseBody))
                        {
                            <div class="section-actions">
                                <button class="copy-button" @onclick="() => CopyToClipboard(Row.ResponseBody)">Copy</button>
                                @if (FrontendSettings.EnableCyberChef)
                                {
                                    <button class="copy-button" @onclick="() => SendToCyberChef(Row.ResponseBody)">CyberChef</button>
                                }
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Row.ResponseBody))
                    {
                        var (formatted, lang) = FormatBody(Row.ResponseBody, Row.ResponseHeaders);
                        <pre class="code-block"><code id="response-body-code" class="language-@lang">@formatted</code></pre>
                    }
                    else
                    {
                        <p class="no-data">No body</p>
                    }
                </div>
            }
        </div>

        @if (_showResendEditor)
        {
            <div class="resend-editor">
                <div class="resend-header">
                    <h3>Resend Request</h3>
                    <button class="close-button" @onclick="CloseResendEditor">&times;</button>
                </div>
                <div class="resend-form">
                    <div class="resend-row">
                        <select @bind="_resendMethod" class="resend-method">
                            <option>GET</option>
                            <option>POST</option>
                            <option>PUT</option>
                            <option>PATCH</option>
                            <option>DELETE</option>
                            <option>HEAD</option>
                            <option>OPTIONS</option>
                        </select>
                        <input type="text" @bind="_resendUrl" class="resend-url" placeholder="URL" />
                    </div>
                    <div class="resend-section">
                        <label>Headers</label>
                        <textarea @bind="_resendHeaders" class="resend-textarea" rows="6" placeholder="Header-Name: value"></textarea>
                    </div>
                    <div class="resend-section">
                        <label>Body</label>
                        <textarea @bind="_resendBody" class="resend-textarea" rows="8" placeholder="Request body"></textarea>
                    </div>
                    <div class="resend-actions">
                        <button class="resend-send-button" @onclick="SendResendRequest" disabled="@_resendSending">
                            @(_resendSending ? "Sending..." : "Send")
                        </button>
                        @if (_resendError != null)
                        {
                            <span class="resend-error">@_resendError</span>
                        }
                        @if (_resendStatusCode.HasValue)
                        {
                            <span class="resend-status status-@GetStatusClass(_resendStatusCode.Value)">@_resendStatusCode</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public InspectionRow Row { get; set; } = default!;

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public IReadOnlyList<InspectionRow> FilteredRows { get; set; } = Array.Empty<InspectionRow>();

    [Parameter]
    public EventCallback<InspectionRow> OnNavigate { get; set; }

    private string activeTab = "request";
    private ElementReference overlayRef;
    private HashSet<string> jwtExpanded = new();

    private async Task SetTab(string tab)
    {
        activeTab = tab;
        StateHasChanged();
        await Task.Yield();
        await HighlightCode();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await overlayRef.FocusAsync();
            }
            catch (JSDisconnectedException) { }
            await HighlightCode();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape":
                await OnClose.InvokeAsync();
                break;
            case "ArrowDown":
                await NavigateToAdjacentRow(1);
                break;
            case "ArrowUp":
                await NavigateToAdjacentRow(-1);
                break;
        }
    }

    private async Task NavigateToAdjacentRow(int direction)
    {
        if (FilteredRows.Count == 0) return;

        var currentIndex = -1;
        for (int i = 0; i < FilteredRows.Count; i++)
        {
            if (FilteredRows[i].Id == Row.Id)
            {
                currentIndex = i;
                break;
            }
        }

        if (currentIndex < 0) return;

        var nextIndex = currentIndex + direction;
        if (nextIndex >= 0 && nextIndex < FilteredRows.Count)
        {
            await OnNavigate.InvokeAsync(FilteredRows[nextIndex]);
        }
    }

    private async Task HighlightCode()
    {
        try
        {
            await JS.InvokeVoidAsync("syntaxHighlight.highlightAll", "detail-content");
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected
        }
    }

    private static (string FormattedContent, string Language) FormatBody(string body, Dictionary<string, string> headers)
    {
        headers.TryGetValue("Content-Type", out var contentType);
        if (contentType is null)
            headers.TryGetValue("content-type", out contentType);

        return PayloadFormatter.Format(body, contentType);
    }

    private async Task CopyToClipboard(string? text)
    {
        if (string.IsNullOrEmpty(text)) return;
        try
        {
            await JS.InvokeVoidAsync("clipboard.copyText", text);
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected
        }
    }

    private void SendToCyberChef(string? body)
    {
        if (string.IsNullOrEmpty(body)) return;
        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(body));
        NavigationManager.NavigateTo($"/cyberchef?input={Uri.EscapeDataString(base64)}");
    }

    private static bool IsAuthorizationBearer(KeyValuePair<string, string> header)
    {
        return header.Key.Equals("Authorization", StringComparison.OrdinalIgnoreCase)
            && header.Value.StartsWith("Bearer ", StringComparison.OrdinalIgnoreCase);
    }

    private async Task ToggleJwt(string key)
    {
        if (!jwtExpanded.Remove(key))
            jwtExpanded.Add(key);

        StateHasChanged();
        await Task.Yield();
        await HighlightCode();
    }

    private static string GetStatusClass(int statusCode) => statusCode switch
    {
        >= 200 and < 300 => "success",
        >= 300 and < 400 => "redirect",
        >= 400 and < 500 => "client-error",
        >= 500 => "server-error",
        _ => "unknown"
    };

    // Resend editor state
    private bool _showResendEditor;
    private string _resendMethod = "GET";
    private string _resendUrl = "";
    private string _resendHeaders = "";
    private string _resendBody = "";
    private bool _resendSending;
    private string? _resendError;
    private int? _resendStatusCode;

    private void OpenResendEditor()
    {
        _resendMethod = Row.Method;
        _resendUrl = Row.Url;
        _resendHeaders = string.Join("\n", Row.RequestHeaders.Select(h => $"{h.Key}: {h.Value}"));
        _resendBody = Row.RequestBody ?? "";
        _resendError = null;
        _resendStatusCode = null;
        _showResendEditor = true;
    }

    private void CloseResendEditor()
    {
        _showResendEditor = false;
    }

    private async Task SendResendRequest()
    {
        _resendSending = true;
        _resendError = null;
        _resendStatusCode = null;
        StateHasChanged();

        try
        {
            var headers = new Dictionary<string, string>();
            foreach (var line in _resendHeaders.Split('\n', StringSplitOptions.RemoveEmptyEntries))
            {
                var colonIndex = line.IndexOf(':');
                if (colonIndex > 0)
                {
                    headers[line[..colonIndex].Trim()] = line[(colonIndex + 1)..].Trim();
                }
            }

            var request = new ResendRequestDto
            {
                Method = _resendMethod,
                Url = _resendUrl,
                Headers = headers,
                Body = string.IsNullOrWhiteSpace(_resendBody) ? null : _resendBody
            };

            var response = await ApiClient.ResendRequestAsync(request);
            _resendStatusCode = response.StatusCode;
        }
        catch (Exception ex)
        {
            _resendError = ex.Message;
        }
        finally
        {
            _resendSending = false;
        }
    }
}

<style>
.detail-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 100;
    display: flex;
    justify-content: flex-end;
}

.detail-panel {
    width: 1050px;
    max-width: 90vw;
    height: 100vh;
    background: var(--neutral-layer-1);
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 20px rgba(0, 0, 0, 0.3);
    overflow: hidden;
}

.detail-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--neutral-stroke-rest);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    position: relative;
}

.detail-title {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
}

.detail-url {
    font-family: monospace;
    font-size: 0.875rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--neutral-foreground-rest);
}

.detail-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
}

.status-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: calc(var(--control-corner-radius) * 1px);
    font-weight: 600;
    font-size: 0.8rem;
    font-family: monospace;
}

.status-success { background: rgba(0, 128, 0, 0.15); color: #22863a; }
.status-redirect { background: rgba(0, 100, 200, 0.15); color: #0366d6; }
.status-client-error { background: rgba(200, 150, 0, 0.15); color: #b08800; }
.status-server-error { background: rgba(200, 0, 0, 0.15); color: #cb2431; }
.status-unknown { background: rgba(128, 128, 128, 0.15); color: #6a737d; }

.detail-duration {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--neutral-foreground-hint);
}

.detail-time {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--neutral-foreground-hint);
}

.close-button {
    position: absolute;
    top: 12px;
    right: 12px;
    background: none;
    border: none;
    color: var(--neutral-foreground-rest);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: calc(var(--control-corner-radius) * 1px);
    line-height: 1;
}

.close-button:hover {
    background: var(--neutral-layer-3);
}

.detail-tabs {
    display: flex;
    border-bottom: 1px solid var(--neutral-stroke-rest);
    padding: 0 20px;
}

.tab {
    background: none;
    border: none;
    padding: 10px 20px;
    cursor: pointer;
    color: var(--neutral-foreground-hint);
    font-size: 0.875rem;
    font-weight: 500;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
}

.tab:hover {
    color: var(--neutral-foreground-rest);
}

.tab.active {
    color: var(--accent-foreground-rest);
    border-bottom-color: var(--accent-foreground-rest);
}

.detail-body {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
}

.section {
    margin-bottom: 24px;
}

.section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
}

.section-header h3 {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--neutral-foreground-rest);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.copy-button {
    background: var(--neutral-layer-3);
    border: 1px solid var(--neutral-stroke-rest);
    color: var(--neutral-foreground-rest);
    padding: 4px 12px;
    border-radius: calc(var(--control-corner-radius) * 1px);
    cursor: pointer;
    font-size: 0.75rem;
}

.copy-button:hover {
    background: var(--neutral-layer-2);
}

.section-actions {
    display: flex;
    gap: 4px;
}

.headers-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
}

.headers-table tr {
    border-bottom: 1px solid var(--neutral-stroke-divider-rest);
}

.headers-table td {
    padding: 6px 8px;
    vertical-align: top;
}

.header-name {
    font-weight: 600;
    font-family: monospace;
    white-space: nowrap;
    color: var(--accent-foreground-rest);
    width: 200px;
}

.header-value {
    font-family: monospace;
    word-break: break-all;
    color: var(--neutral-foreground-rest);
}

.code-block {
    margin: 0;
    border-radius: calc(var(--control-corner-radius) * 1px);
    overflow-x: auto;
    max-height: 500px;
    overflow-y: auto;
}

.code-block code {
    font-size: 0.8rem;
    line-height: 1.5;
}

.no-data {
    color: var(--neutral-foreground-hint);
    font-style: italic;
    font-size: 0.875rem;
}

.jwt-header {
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.jwt-toggle {
    display: flex;
    align-items: center;
    gap: 4px;
}

.jwt-decode-btn {
    background: var(--neutral-layer-3);
    border: 1px solid var(--neutral-stroke-rest);
    color: var(--accent-foreground-rest);
    padding: 2px 8px;
    border-radius: calc(var(--control-corner-radius) * 1px);
    cursor: pointer;
    font-size: 0.7rem;
    font-weight: 600;
}

.jwt-decode-btn:hover {
    background: var(--neutral-layer-2);
}

.jwt-decode-btn.active {
    background: var(--accent-foreground-rest);
    color: white;
    border-color: var(--accent-foreground-rest);
}

.jwt-copy-btn {
    background: var(--neutral-layer-3);
    border: 1px solid var(--neutral-stroke-rest);
    color: var(--neutral-foreground-hint);
    padding: 2px;
    border-radius: calc(var(--control-corner-radius) * 1px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
}

.jwt-copy-btn:hover {
    background: var(--neutral-layer-2);
    color: var(--neutral-foreground-rest);
}

.jwt-decoded {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 4px;
}

.jwt-section {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.jwt-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--neutral-foreground-hint);
    letter-spacing: 0.05em;
}

.jwt-json {
    margin: 0;
    border-radius: calc(var(--control-corner-radius) * 1px);
    font-size: 0.75rem;
    max-height: 200px;
    overflow-y: auto;
}

.jwt-signature {
    font-size: 0.75rem;
    word-break: break-all;
    color: var(--neutral-foreground-hint);
}

.tab-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
}

.resend-button {
    background: var(--accent-fill-rest);
    color: var(--foreground-on-accent-rest);
    border: none;
    border-radius: 4px;
    padding: 4px 12px;
    cursor: pointer;
    font-size: 0.8rem;
}

.resend-button:hover {
    background: var(--accent-fill-hover);
}

.resend-editor {
    border-top: 1px solid var(--neutral-stroke-rest);
    padding: 1rem;
}

