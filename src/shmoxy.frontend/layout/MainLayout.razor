@inherits LayoutComponentBase
@inject ThemeState ThemeState
@inject FrontendSettings FrontendSettings
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@implements IDisposable

<FluentDesignTheme @ref="_theme" @bind-Mode="_mode" StorageName="preferred-theme">
    <div class="layout">
        <header class="header">
            <div class="header-left">
                <img src="_content/shmoxy.frontend/icon.png" alt="Shmoxy" style="width:24px;height:24px;" />
                <span class="header-title">Shmoxy</span>
            </div>
            <div class="header-right">
                <ProxyStatusIndicator />
                @if (FrontendSettings.EnableCyberChef)
                {
                    <FluentButton Appearance="Appearance.Stealth" Title="Send to CyberChef" OnClick="@OpenCyberChefDialog">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Beaker())" />
                    </FluentButton>
                }
                <FluentAnchor Href="/settings" Appearance="Appearance.Stealth" Title="Settings">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Settings())" />
                </FluentAnchor>
            </div>
        </header>

        <div class="body">
            <nav class="icon-sidebar">
                <NavLink href="/" Match="NavLinkMatch.All" class="nav-item" title="Inspection">
                    <FluentIcon Value="@(new Icons.Regular.Size20.DocumentSearch())" />
                    <span>Inspection</span>
                </NavLink>
                <NavLink href="/proxy-config" Match="NavLinkMatch.Prefix" class="nav-item" title="Proxy Config">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Server())" />
                    <span>Proxy</span>
                </NavLink>
                <NavLink href="/breakpoints" Match="NavLinkMatch.Prefix" class="nav-item" title="Breakpoints">
                    <FluentIcon Value="@(new Icons.Regular.Size20.PauseCircle())" />
                    <span>Breakpoints</span>
                </NavLink>
                @if (FrontendSettings.EnableCyberChef)
                {
                    <NavLink href="/cyberchef" Match="NavLinkMatch.Prefix" class="nav-item" title="CyberChef">
                        <FluentIcon Value="@(new Icons.Regular.Size20.Wrench())" />
                        <span>CyberChef</span>
                    </NavLink>
                }
                <NavLink href="/settings" Match="NavLinkMatch.Prefix" class="nav-item" title="Settings">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Settings())" />
                    <span>Settings</span>
                </NavLink>
                <div class="nav-spacer"></div>
                <NavLink href="/about" Match="NavLinkMatch.Prefix" class="nav-item" title="About">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Info())" />
                    <span>About</span>
                </NavLink>
            </nav>

            <main class="content">
                @Body
            </main>
        </div>
    </div>

    @if (showCyberChefDialog)
    {
        <FluentDialog @bind-Hidden="@cyberChefDialogHidden" Modal="true" TrapFocus="true" PreventDismissOnOverlayClick="false" @ondialogdismiss="CloseCyberChefDialog">
            <FluentDialogHeader>
                <h3 style="margin:0;">Send to CyberChef</h3>
            </FluentDialogHeader>
            <FluentDialogBody>
                <FluentTextArea @bind-Value="cyberChefInput" Placeholder="Paste text to analyze..." Rows="10" style="width:100%;" />
            </FluentDialogBody>
            <FluentDialogFooter>
                <FluentButton Appearance="Appearance.Accent" OnClick="@SendToCyberChef" Disabled="@string.IsNullOrWhiteSpace(cyberChefInput)">
                    Send
                </FluentButton>
                <FluentButton Appearance="Appearance.Stealth" OnClick="@CloseCyberChefDialog">
                    Cancel
                </FluentButton>
            </FluentDialogFooter>
        </FluentDialog>
    }

    <FluentToastProvider />
    <FluentDialogProvider />
    <FluentTooltipProvider />
</FluentDesignTheme>

@code {
    private FluentDesignTheme? _theme;
    private DesignThemeModes _mode = DesignThemeModes.Dark;

    protected override void OnInitialized()
    {
        ThemeState.OnChange += OnThemeStateChanged;
        FrontendSettings.OnChange += OnFrontendSettingsChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await FrontendSettings.LoadAsync(JS);
            StateHasChanged();
            try
            {
                await JS.InvokeVoidAsync("themeSync.setTheme", _mode == DesignThemeModes.Dark);
            }
            catch (JSDisconnectedException) { }
        }
    }

    private void OnThemeStateChanged()
    {
        _mode = ThemeState.Mode;
        InvokeAsync(async () =>
        {
            StateHasChanged();
            try
            {
                await JS.InvokeVoidAsync("themeSync.setTheme", _mode == DesignThemeModes.Dark);
            }
            catch (JSDisconnectedException) { }
        });
    }

    private void OnFrontendSettingsChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private bool showCyberChefDialog;
    private bool cyberChefDialogHidden = true;
    private string cyberChefInput = string.Empty;

    private void OpenCyberChefDialog()
    {
        cyberChefInput = string.Empty;
        showCyberChefDialog = true;
        cyberChefDialogHidden = false;
    }

    private void CloseCyberChefDialog()
    {
        showCyberChefDialog = false;
        cyberChefDialogHidden = true;
    }

    private void SendToCyberChef()
    {
        if (string.IsNullOrWhiteSpace(cyberChefInput))
            return;

        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(cyberChefInput));
        CloseCyberChefDialog();
        NavigationManager.NavigateTo($"/cyberchef?input={Uri.EscapeDataString(base64)}");
    }

    public void Dispose()
    {
        ThemeState.OnChange -= OnThemeStateChanged;
        FrontendSettings.OnChange -= OnFrontendSettingsChanged;
    }
}
